{{#if session.user}}
<!-- ===== DASHBOARD: SESION ACTIVA ===== -->
<div class="container">
    <div class="dashboard-welcome">
        <div class="welcome-avatar">
            <!-- Icono: usuario -->
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
        </div>
        <h2>Hola, {{session.user.username}}</h2>
        <p class="welcome-sub">Bienvenido de nuevo a tu panel de control</p>
    </div>

    <div class="dashboard-cards">
        <a href="/productos" class="dash-card dash-card-primary">
            <div class="dash-card-icon">
                <!-- Icono: caja -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                </svg>
            </div>
            <h3>Mis Productos</h3>
            <p>Gestiona tu inventario: agrega, edita o elimina productos facilmente.</p>
            <span class="dash-card-link">
                Ir a Productos
                <!-- Icono: flecha derecha -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </span>
        </a>

        <a href="/productos/nuevo" class="dash-card dash-card-success">
            <div class="dash-card-icon">
                <!-- Icono: mas en circulo -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="16"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
            </div>
            <h3>Nuevo Producto</h3>
            <p>Registra un nuevo articulo en tu inventario con imagen, precio y descripcion.</p>
            <span class="dash-card-link">
                Agregar Ahora
                <!-- Icono: flecha derecha -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </span>
        </a>
    </div>
</div>

{{else}}
<!-- ===== LANDING PAGE: SIN SESION ===== -->
<div class="container">
    <div class="home-hero">
        <div class="hero-icon">
            <!-- Icono: caja grande -->
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
        </div>
        <h2>Bienvenido a MiInventarioExpress</h2>
        <p>Sistema profesional de gestion de productos en linea. Administra tu inventario de forma rapida, segura y desde cualquier lugar.</p>
        <div class="home-actions">
            <a href="/login" class="btn btn-primary">
                <!-- Icono: login -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
                    <polyline points="10 17 15 12 10 7"/>
                    <line x1="15" y1="12" x2="3" y2="12"/>
                </svg>
                Iniciar Sesion
            </a>
            <a href="/register" class="btn btn-outline">
                <!-- Icono: usuario + -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="8.5" cy="7" r="4"/>
                    <line x1="20" y1="8" x2="20" y2="14"/>
                    <line x1="23" y1="11" x2="17" y2="11"/>
                </svg>
                Registrarse
            </a>
        </div>

        <div class="home-features">
            <div class="feature-card">
                <!-- Icono: lista -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="8" y1="6" x2="21" y2="6"/>
                    <line x1="8" y1="12" x2="21" y2="12"/>
                    <line x1="8" y1="18" x2="21" y2="18"/>
                    <line x1="3" y1="6" x2="3.01" y2="6"/>
                    <line x1="3" y1="12" x2="3.01" y2="12"/>
                    <line x1="3" y1="18" x2="3.01" y2="18"/>
                </svg>
                <h4>Gestion de Productos</h4>
                <p>Registra, edita y organiza todos tus productos con imagenes, precios y descripciones.</p>
            </div>
            <div class="feature-card">
                <!-- Icono: chat -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                <h4>Chat en Tiempo Real</h4>
                <p>Comunicate al instante con otros usuarios del sistema mediante el chat integrado.</p>
            </div>
            <div class="feature-card">
                <!-- Icono: escudo -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                <h4>Acceso Seguro</h4>
                <p>Cuentas protegidas con sesiones cifradas. Solo tu tienes acceso a tu inventario.</p>
            </div>
            <div class="feature-card">
                <!-- Icono: nube / servidor -->
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/>
                </svg>
                <h4>Siempre Disponible</h4>
                <p>Almacenamiento en la nube con MongoDB. Tus datos siempre respaldados y accesibles.</p>
            </div>
        </div>
    </div>
</div>
{{/if}}