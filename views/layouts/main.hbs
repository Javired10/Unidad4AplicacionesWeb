<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MiInventarioExpress</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar">
        <a href="/" class="navbar-brand">
            <!-- Icono: caja / paquete -->
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            Mi Inventario
        </a>
        <div class="navbar-actions">
            {{#if session.user}}
                <span class="navbar-user">
                    <!-- Icono: usuario -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                    {{session.user.username}}
                </span>
                <a href="/logout" class="btn btn-light">
                    <!-- Icono: salir -->
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Cerrar Sesion
                </a>
            {{else}}
                <a href="/login" class="btn btn-light">Iniciar Sesion</a>
                <a href="/register" class="btn btn-light">Registrarse</a>
            {{/if}}
        </div>
    </nav>

    <!-- ===== MAIN CONTENT ===== -->
    {{{body}}}

    <!-- ===== CHAT (solo si hay sesion) ===== -->
    {{#if session.user}}
        <button class="chat-fab" id="chatFab" title="Abrir chat" onclick="toggleChat()">
            <!-- Icono: mensaje / chat -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
        </button>

        <div class="chat-window" id="chatWindow">
            <div class="chat-header">
                <span class="dot"></span>
                Chat en vivo
            </div>
            <div class="chat-messages" id="messages"></div>
            <div class="chat-input-area">
                <input type="text" id="m" placeholder="Escribe un mensaje..." onkeydown="if(event.key==='Enter') sendMessage()">
                <button onclick="sendMessage()" title="Enviar">
                    <!-- Icono: enviar / flecha arriba -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="19" x2="12" y2="5"/>
                        <polyline points="5 12 12 5 19 12"/>
                    </svg>
                </button>
            </div>
        </div>
    {{/if}}

    <!-- ===== SCRIPTS ===== -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const currentUser = "{{session.user.username}}";

        function toggleChat() {
            const win = document.getElementById('chatWindow');
            win.classList.toggle('open');
            if (win.classList.contains('open')) {
                document.getElementById('m').focus();
            }
        }

        function sendMessage() {
            const input = document.getElementById('m');
            const text = input.value.trim();
            if (!text) return;
            socket.emit('chat message', text);
            input.value = '';
        }

        socket.on('chat message', (data) => {
            const container = document.getElementById('messages');
            const div = document.createElement('div');
            div.classList.add('msg');
            const isMine = data.user === currentUser;
            div.classList.add(isMine ? 'msg-out' : 'msg-in');
            div.innerHTML = '<span class="user">' + (data.user || 'Anonimo') + '</span>' + (data.text || data);
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        });
    </script>

</body>
</html>