<div class="container">
    <div class="form-card">
        <h2>
            {{#if producto}}
                <!-- Icono: lapiz -->
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
                Editar Producto
            {{else}}
                <!-- Icono: mas en circulo -->
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="16"/>
                    <line x1="8" y1="12" x2="16" y2="12"/>
                </svg>
                Nuevo Producto
            {{/if}}
        </h2>

        <form action="{{#if producto}}/productos/editar/{{producto._id}}{{else}}/productos{{/if}}" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label for="nombre">Nombre del Producto</label>
                <input type="text" id="nombre" name="nombre" value="{{producto.nombre}}" placeholder="Ej: Laptop HP Pavilion" required>
            </div>

            <div class="form-group">
                <label for="precio">Precio (USD)</label>
                <input type="number" id="precio" step="0.01" min="0" name="precio" value="{{producto.precio}}" placeholder="0.00" required>
            </div>

            <div class="form-group">
                <label for="descripcion">Descripcion</label>
                <textarea id="descripcion" name="descripcion" rows="3" placeholder="Describe el producto...">{{producto.descripcion}}</textarea>
            </div>

            <div class="form-group">
                <label for="imagen">
                    {{#if producto}}
                        Imagen del Producto
                    {{else}}
                        Imagen del Producto
                    {{/if}}
                </label>
                <input type="file" id="imagen" name="imagen" accept="image/*" {{#unless producto}}required{{/unless}}>
                {{#if producto}}
                    <p class="form-hint">Deja este campo vacio si no deseas cambiar la imagen actual.</p>
                {{else}}
                    <p class="form-hint">Formatos aceptados: JPG, PNG, GIF, WebP.</p>
                {{/if}}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    {{#if producto}}
                        <!-- Icono: guardar -->
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/>
                            <polyline points="7 3 7 8 15 8"/>
                        </svg>
                        Actualizar Producto
                    {{else}}
                        <!-- Icono: guardar -->
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
                            <polyline points="17 21 17 13 7 13 7 21"/>
                            <polyline points="7 3 7 8 15 8"/>
                        </svg>
                        Guardar Producto
                    {{/if}}
                </button>
                <a href="/productos" class="btn btn-outline">
                    <!-- Icono: X / cancelar -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                    Cancelar
                </a>
                {{#if producto}}
                <button type="submit" formaction="/productos/eliminar/{{producto._id}}" formmethod="POST" class="btn btn-danger"
                    onclick="return confirm('Estas seguro de eliminar este producto? Esta accion no se puede deshacer.')">
                    <!-- Icono: basura -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                    Eliminar
                </button>
                {{/if}}
            </div>
        </form>

        <a href="/productos" class="back-link">
            <!-- Icono: flecha izquierda -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
            </svg>
            Volver al listado
        </a>
    </div>
</div>