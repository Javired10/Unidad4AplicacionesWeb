# MongoDB Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/miInventario?retryWrites=true&w=majority

# Port for the server to run on (Railway provides this automatically)
PORT=3000

# URL of the frontend for CORS configuration (e.g., https://your-app.netlify.app)
FRONTEND_URL=http://localhost:5173

# Secret key for session management
SESSION_SECRET=cambia-esto-por-un-valor-seguro

# Environment mode: development or production
NODE_ENV=development